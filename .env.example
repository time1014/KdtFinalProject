# Docker 운영 배포용 환경변수 예시입니다.
# 실제 운영 서버에서는 이 파일을 .env로 복사한 뒤 실제 값을 입력합니다.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=80

# Jasypt 암호화 키
JASYPT_PASSWORD=change-me

# GitHub API 조회 토큰
GITHUB_API_TOKEN=

# S3 운영 버킷 연결
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=weple-cloud-files

# 컨테이너 내부 파일 경로
FILE_UPLOAD_TASK_DIR=/uploadtest/tasks/
FILE_UPLOAD_PROFILE_DIR=/uploadtest/profile/
