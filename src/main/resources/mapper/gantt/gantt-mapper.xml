<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weple.cloud.gantt.mapper.GanttMapper">
	<select id="selectTaskAll" resultType="TaskVO">
		SELECT * 
		FROM task 
		WHERE project_id = #{projectId} AND deleted_yn = 'N'
	</select>
	
	
	<resultMap id="GanttMilestoneBaseMap" type="MilestoneInfoVO">
        <id property="milestoneId" column="milestone_id"/>
        <result property="projectId" column="project_id"/>
        <result property="userCode" column="user_code"/> 
        <result property="milestoneTitle" column="milestone_title"/>
        <result property="milestoneDescribe" column="milestone_describe"/>
        <result property="finishDate" column="finish_date"/>
        <result property="milestoneStatus" column="milestone_status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="parentMilestoneId" column="parent_milestone_id"/>
    </resultMap>

    <resultMap id="GanttParentMilestoneMap" type="MilestoneInfoVO" extends="GanttMilestoneBaseMap">
        <collection property="childMilestones" ofType="MilestoneInfoVO" resultMap="GanttChildMilestoneMap"/>
    </resultMap>
    
    <resultMap id="GanttChildMilestoneMap" type="MilestoneInfoVO">
        <id property="milestoneId" column="child_milestone_id"/>
        <result property="projectId" column="child_project_id"/>
        <result property="userCode" column="child_user_code"/> 
        <result property="milestoneTitle" column="child_milestone_title"/>
        <result property="milestoneDescribe" column="child_milestone_describe"/>
        <result property="finishDate" column="child_finish_date"/>
        <result property="milestoneStatus" column="child_milestone_status"/>
        <result property="createdAt" column="child_created_at"/>
        <result property="updatedAt" column="child_updated_at"/>
        <result property="parentMilestoneId" column="milestone_id"/>
    </resultMap>

    <select id="selectMilestoneForGantt" parameterType="long" resultMap="GanttParentMilestoneMap">
        SELECT 
            /* ======= 최상위(부모) 마일스톤 ======= */
            m.milestone_id, 
            m.project_id, 
            m.user_code, 
            m.milestone_title, 
            m.milestone_describe, 
            m.finish_date, 
            m.milestone_status,
            m.created_at,
            m.updated_at,
            
            /* ======= 하위(자식) 마일스톤 (child_ 접두어) ======= */
            c.milestone_id                     AS child_milestone_id,
            c.project_id                       AS child_project_id,
            c.user_code                        AS child_user_code,
            c.milestone_title                  AS child_milestone_title,
            c.milestone_describe               AS child_milestone_describe,
            c.finish_date                      AS child_finish_date,
            c.milestone_status                 AS child_milestone_status,
            c.created_at                       AS child_created_at,
            c.updated_at                       AS child_updated_at
            
        FROM milestone m
        LEFT JOIN milestone c ON m.milestone_id = c.parent_milestone_id
        WHERE m.project_id = #{projectId} 
          AND m.parent_milestone_id IS NULL
        ORDER BY m.created_at DESC, c.created_at ASC
    </select>
    
    <select id="isModuleActive" parameterType="map" resultType="int">
        SELECT COUNT(*)
        FROM module_mapping
        WHERE project_id = #{projectId}
          AND module_name = #{moduleName}
          AND is_active = 'Y'
    </select>
    
    <select id="checkProjectMembership" parameterType="map" resultType="int">
	    SELECT COUNT(*)
	    FROM members
	    WHERE PROJECT_ID = #{projectId}
	      AND USER_CODE = #{userCode}
	</select>
	
</mapper>