<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weple.cloud.system.mapper.RoleMapper">
<!-- 역할 목록 조회 -->
	<select id="selectRoleList" resultType="com.weple.cloud.system.service.RoleVO">
	SELECT
            r.role_id,
            r.company_id,
            r.role_name,
            c.created_at
        FROM roles r
        LEFT JOIN companies c ON r.company_id = c.company_id
        ORDER BY r.role_id
	</select>
</mapper>